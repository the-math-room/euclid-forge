{
  "name": "euclid-forge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "typecheck": "tsc --noEmit",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "smoke": "playwright test --config=playwright.config.ts",
    "check": "npm run typecheck && npm test && npm run check:boundaries && npm run smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
