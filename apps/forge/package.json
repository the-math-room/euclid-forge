{
  "name": "euclid-forge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "typecheck": "tsc --noEmit",
    "check:boundaries": "node ../../scripts/check-boundaries.mjs",
    "smoke": "playwright test --config=playwright.config.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "npm run typecheck && npm test && npm run check:boundaries && npm run smoke",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@euclid-forge/core": "0.1.0"
  }
}
